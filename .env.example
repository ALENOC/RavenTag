# ─── Ravencoin Node ──────────────────────────────────────────────────────────
# Local Ravencoin full node RPC
RVN_RPC_HOST=localhost
RVN_RPC_PORT=8766
RVN_RPC_USER=rpcuser
RVN_RPC_PASS=rpcpassword

# Public fallback node (used if local node is unreachable)
RVN_PUBLIC_RPC_URL=https://rvn-rpc.publicnode.com

# ─── Security ────────────────────────────────────────────────────────────────
# Random string used as the admin API key (X-Admin-Key header)
# Generate with: openssl rand -hex 32
ADMIN_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://raventag.com,https://www.raventag.com

# ─── Frontend (public env vars — exposed to browser) ─────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://api.raventag.com
NEXT_PUBLIC_RVN_RPC_URL=https://rvn-rpc.publicnode.com
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Demo/default NFC keys (for web verify demo — replace with actual brand keys in production)
NEXT_PUBLIC_DEMO_SDMMAC_KEY=
NEXT_PUBLIC_DEMO_SUN_MAC_KEY=
NEXT_PUBLIC_DEMO_SALT=
NEXT_PUBLIC_DEMO_ASSET=

# ─── Cache TTL (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_ASSET=300
CACHE_TTL_IPFS=3600

# ─── Deployment ───────────────────────────────────────────────────────────────
# Public URL of the backend (for docker-compose service discovery)
NEXT_PUBLIC_BACKEND_URL=https://api.raventag.com
