PORT=3001
NODE_ENV=development

# Ravencoin RPC (local node)
RVN_RPC_HOST=localhost
RVN_RPC_PORT=8766
RVN_RPC_USER=rpcuser
RVN_RPC_PASS=rpcpassword

# Public Ravencoin node (fallback when local node not available)
RVN_PUBLIC_RPC_URL=https://rvn-rpc.publicnode.com

# IPFS
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Admin API key — full access (issue assets, revoke, transfer, manage)
ADMIN_KEY=change-me-in-production

# Allowed CORS origins (comma-separated). Set to your frontend URL in production.
ALLOWED_ORIGINS=http://localhost:3000

# Operator key — restricted access (register chips, list chips only)
# Assign to factory/warehouse operators who program NFC tags
# If not set, only ADMIN_API_KEY is accepted for operator routes
# OPERATOR_KEY=operator-key-for-factory

# Cache TTL (seconds)
CACHE_TTL_ASSET=300
CACHE_TTL_IPFS=3600

# Brand sovereign keys — stored ONLY on the brand's server, never in the browser
# BRAND_MASTER_KEY: AES-128 master key (32 hex chars = 16 bytes), cryptographically random
# Used to derive per-chip keys: Derived_Key = AES-128-ECB(BRAND_MASTER_KEY, UID_padded)
BRAND_MASTER_KEY=

# BRAND_SALT: 16-byte salt (32 hex chars), cryptographically random
# Used to compute nfc_pub_id = SHA-256(uid || BRAND_SALT)
# The salt makes it impossible to reverse-engineer the chip UID from blockchain data.
BRAND_SALT=

# Testnet configuration
TESTNET=false                          # Set to true to use Ravencoin testnet
# Testnet Ravencoin node (if TESTNET=true, use port 18766 typically)
# RVN_RPC_PORT=18766

# Direct download URL for the RavenTag Verify APK shown on the browser install page.
# Update this with each new release. Falls back to the releases/latest page if not set.
# VERIFY_APK_URL=https://github.com/ALENOC/RavenTag/releases/download/v1.3.0/RavenTag-Verify-v1.3.0.apk

# SHA-256 certificate fingerprint for Android App Links verification.
# Generate with: keytool -list -v -keystore your.keystore -alias your_alias
# ANDROID_APP_FINGERPRINT=AA:BB:CC:...
